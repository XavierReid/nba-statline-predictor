# Copy to .env and fill in for local development.

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg2://nba:nba@localhost:5432/nba_predictor

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Predictor weights (all optional — defaults are sane)
PREDICTOR_W_RECENT=0.50
PREDICTOR_W_SEASON=0.30
PREDICTOR_W_VS_OPPONENT=0.20
PREDICTOR_RECENT_GAMES_WINDOW=10
